# ======================================
# CONFIGURATION ENVIRONNEMENT - PythonAnywhere
# ======================================
# Copiez ce fichier en .env et remplissez avec vos vraies valeurs
# Sur PythonAnywhere : cd ~/investlink && nano .env

# ======================================
# DJANGO CORE
# ======================================
DEBUG=False
SECRET_KEY=votre-clé-secrète-super-longue-et-aléatoire-ici

# Générer une clé sécurisée avec :
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# Compte gratuit : utilisez votre sous-domaine PythonAnywhere
ALLOWED_HOSTS=VOTRE_USERNAME.pythonanywhere.com

# Compte payant : ajoutez votre domaine personnalisé
# ALLOWED_HOSTS=VOTRE_USERNAME.pythonanywhere.com,votredomaine.com,www.votredomaine.com

# ======================================
# BASE DE DONNÉES
# ======================================
# Compte gratuit : SQLite (par défaut, pas besoin de renseigner)
# Compte payant : PostgreSQL
# DATABASE_URL=postgresql://username:password@hostname:port/database_name

# Pour obtenir vos infos PostgreSQL sur PythonAnywhere :
# 1. Allez dans l'onglet "Databases"
# 2. Créez une base de données PostgreSQL
# 3. Notez : host, port, username, password, database name
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ======================================
# CLOUDINARY (Fichiers Media en Production)
# ======================================
# Obligatoire pour stocker les images/fichiers uploadés en production
# Créez un compte gratuit sur https://cloudinary.com
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ======================================
# EMAIL (Optionnel)
# ======================================
# Configuration pour l'envoi d'emails

# Gmail (nécessite un mot de passe d'application)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-app
DEFAULT_FROM_EMAIL=noreply@investlink.com

# Autres fournisseurs :
# SendGrid : smtp.sendgrid.net (port 587)
# Mailgun : smtp.mailgun.org (port 587)
# Amazon SES : email-smtp.us-east-1.amazonaws.com (port 587)

# Mode console (développement - affiche les emails dans les logs)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ======================================
# CONNEXION BASE DE DONNÉES (Avancé)
# ======================================
# Pour comptes payants avec PostgreSQL
# CONN_MAX_AGE=600

# ======================================
# NOTES IMPORTANTES
# ======================================
# 1. Ne commitez JAMAIS ce fichier .env sur GitHub
# 2. Gardez vos clés secrètes confidentielles
# 3. Utilisez des mots de passe forts et uniques
# 4. Pour Gmail, utilisez un mot de passe d'application, pas votre mot de passe principal
# 5. Rechargez l'app après avoir modifié ce fichier
